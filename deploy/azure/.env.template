# Azure settings
AZURE_RESOURCE_GROUP=ai-triad
AZURE_LOCATION=eastus
CONTAINER_IMAGE=ghcr.io/jpsnover/taxonomy-editor:latest

# Authentication mode (pick one):
#   AUTH_DISABLED=1        — no login page, everyone is anonymous (default)
#   AUTH_OPTIONAL=1        — login page with sign-in + anonymous option
#   neither                — required auth (needs authorized-users.json on data volume)
# AUTH_DISABLED=1
# AUTH_OPTIONAL=1

# API keys are NOT configured here.
# Users enter their own keys via the app UI (BYOK model).
# Keys are encrypted and stored on the Azure Files data volume.
