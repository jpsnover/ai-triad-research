{
  "name": "poviewer",
  "version": "0.1.0",
  "private": true,
  "description": "Three-pane POV viewer for BKC AI Triad research documents",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "licenses": "generate-license-file --input package.json --output THIRD-PARTY-NOTICES.txt --eol lf",
    "build": "tsc -p tsconfig.main.json && vite build && npm run licenses"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "electron": "^41.1.1",
    "generate-license-file": "^4.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^8.0.0"
  }
}
