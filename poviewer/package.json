{
  "name": "poviewer",
  "version": "0.1.0",
  "private": true,
  "description": "Three-pane POV viewer for BKC AI Triad research documents",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "tsc -p tsconfig.main.json && vite build"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "wait-on": "^8.0.0"
  }
}
