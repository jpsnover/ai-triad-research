{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/main",
    "rootDir": "../",
    "baseUrl": ".",
    "paths": {
      "jszip": ["./node_modules/jszip"]
    }
  },
  "include": [
    "src/main/**/*",
    "../lib/ai-client/**/*",
    "../lib/debate/debateExport.ts",
    "../lib/debate/errors.ts",
    "../lib/debate/taxonomyLoader.ts",
    "../lib/debate/taxonomyTypes.ts",
    "../lib/debate/taxonomyContext.ts",
    "../lib/search/**/*"
  ]
}
