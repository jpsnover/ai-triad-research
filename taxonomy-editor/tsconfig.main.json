{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist/main",
    "rootDir": "../"
  },
  "include": [
    "src/main/**/*",
    "../lib/debate/debateExport.ts",
    "../lib/debate/taxonomyLoader.ts",
    "../lib/debate/taxonomyTypes.ts",
    "../lib/debate/taxonomyContext.ts"
  ]
}
