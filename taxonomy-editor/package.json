{
  "name": "taxonomy-editor",
  "version": "0.6.5",
  "private": true,
  "description": "Visual editor for AI Triad Research taxonomy JSON files",
  "main": "dist/main/taxonomy-editor/src/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:web": "cross-env VITE_TARGET=web vite --host 0.0.0.0",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "tsc -p tsconfig.main.json && vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "cross-env VITE_TARGET=web vite build",
    "build:container": "npm run build:server && npm run build:web",
    "start:server": "node dist/server/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.0"
  }
}
