{
  "name": "taxonomy-editor",
  "version": "0.7.4",
  "private": true,
  "description": "Visual editor for AI Triad Research taxonomy JSON files",
  "homepage": "https://github.com/jpsnover/ai-triad-research",
  "author": {
    "name": "Jeffrey Snover",
    "email": "jsnover13@gmail.com"
  },
  "main": "dist/main/taxonomy-editor/src/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:web": "cross-env VITE_TARGET=web vite --host 0.0.0.0",
    "dev:server": "npm run build:server && node dist/server/server.js",
    "dev:container": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "licenses": "generate-license-file --input package.json --output THIRD-PARTY-NOTICES.txt --eol lf && node scripts/parse-licenses.js",
    "build": "tsc -p tsconfig.main.json && vite build && npm run licenses",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "cross-env VITE_TARGET=web vite build",
    "build:container": "npm run build:server && npm run build:web && npm run licenses",
    "start:server": "node dist/server/server.js",
    "postinstall": "npx @electron/rebuild || true",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/identity": "^4.4.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "jszip": "^3.10.1",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "generate-license-file": "^4.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.0"
  }
}
