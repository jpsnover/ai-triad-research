{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@bridge": ["src/renderer/bridge/index.ts"],
      "@renderer/*": ["src/renderer/*"],
      "@lib/debate": ["../lib/debate/index.ts"],
      "@lib/debate/*": ["../lib/debate/*"],
      "@lib/dictionary": ["../lib/dictionary/index.ts"],
      "@lib/dictionary/*": ["../lib/dictionary/*"],
      "@lib/translation": ["../lib/translation/index.ts"],
      "@lib/translation/*": ["../lib/translation/*"],
      "@lib/search/*": ["../lib/search/*"],
      "@lib/flight-recorder/*": ["../lib/flight-recorder/*"],
      "@lib/flight-recorder/index": ["../lib/flight-recorder/index.ts"],
      "zod": ["node_modules/zod"]
    }
  },
  "include": ["src/**/*", "../lib/**/*"],
  "exclude": ["node_modules", "dist"]
}
