{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "rootDir": "../",
    "declaration": false
  },
  "include": ["src/server/**/*", "../lib/ai-client/**/*", "../lib/search/**/*", "../lib/flight-recorder/**/*"],
  "exclude": ["node_modules", "dist", "../lib/**/*.test.ts"]
}
